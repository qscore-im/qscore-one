{
  "name": "volleyball-scoreboard",
  "version": "1.0.0",
  "description": "Real-time volleyball scoreboard — Socket.io locally, Firebase in production",
  "main": "server.js",
  "scripts": {
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.json && tsc -p tsconfig.tests.json --noEmit",
    "start": "npm run build && node server.js",
    "dev": "node --watch server.js",
    "deploy": "npm run build && firebase deploy",
    "deploy:cloudflare": "npm run build && wrangler deploy",
    "cf:dev": "wrangler dev",
    "test": "npm run build && playwright test"
  },
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "firebase-tools": "^15.12.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=24"
  }
}
