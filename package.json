    "cf:dev": "wrangler dev",
    "test": "playwright test"
  },
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "firebase-tools": "^15.12.0",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=24"
  }
}
