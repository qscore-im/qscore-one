{
  "name": "volleyball-scoreboard",
  "version": "1.0.0",
  "description": "Real-time volleyball scoreboard — Socket.io locally, Firebase in production",
  "main": "server.js",
  "scripts": {
    "start":             "node server.js",
    "dev":               "node --watch server.js",
    "deploy":            "firebase deploy",
    "deploy:cloudflare": "wrangler deploy",
    "cf:dev":            "wrangler dev",
    "test":              "playwright test"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "firebase-tools": "^15.12.0",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=18"
  }
}
